# LiveKit Cloud credentials
# Get these from https://cloud.livekit.io → Project Settings
LIVEKIT_URL=wss://your-project.livekit.cloud
LIVEKIT_API_KEY=your_livekit_api_key
LIVEKIT_API_SECRET=your_livekit_api_secret

# OpenAI API key (used for GPT-4o LLM + TTS)
# Get from https://platform.openai.com/api-keys
OPENAI_API_KEY=your_openai_api_key

# Deepgram API key (used for STT)
# Get from https://console.deepgram.com — $200 free credit on signup
DEEPGRAM_API_KEY=your_deepgram_api_key

# OpenClaw Gateway — routes LLM through the local Alex agent (memory, tools, persona)
# Get token from: openclaw gateway status, or ~/.openclaw/openclaw.json → gateway.auth.token
# Leave OPENCLAW_GATEWAY_TOKEN blank to fall back to direct GPT-4o
OPENCLAW_GATEWAY_URL=http://127.0.0.1:18789/v1
OPENCLAW_GATEWAY_TOKEN=your_openclaw_gateway_token
# Stable session key — all voice calls route to this named session so Alex retains memory
OPENCLAW_SESSION_KEY=agent:alex:voice:andrew
