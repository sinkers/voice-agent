# =============================================================================
# LiveKit Voice Agent — environment configuration
# Copy this file to .env and fill in your values.
# Never commit .env — it contains secrets.
# =============================================================================

# -----------------------------------------------------------------------------
# LiveKit Cloud
# Get these from https://cloud.livekit.io → your project → Settings
# -----------------------------------------------------------------------------
LIVEKIT_URL=wss://your-project.livekit.cloud
LIVEKIT_API_KEY=your_livekit_api_key
LIVEKIT_API_SECRET=your_livekit_api_secret

# -----------------------------------------------------------------------------
# OpenAI
# Used for: GPT-4o LLM (fallback) + TTS
# Get from: https://platform.openai.com/api-keys
# -----------------------------------------------------------------------------
OPENAI_API_KEY=your_openai_api_key

# -----------------------------------------------------------------------------
# Deepgram
# Used for: Speech-to-text (STT)
# Get from: https://console.deepgram.com ($200 free credit on signup)
# -----------------------------------------------------------------------------
DEEPGRAM_API_KEY=your_deepgram_api_key

# -----------------------------------------------------------------------------
# OpenClaw Gateway (optional — enables routing LLM through a local agent)
#
# When set, all LLM calls go through the OpenClaw Gateway instead of directly
# to OpenAI. The agent gets full memory, tools, and persona from the workspace.
# If OPENCLAW_GATEWAY_TOKEN is not set, the agent falls back to direct GPT-4o.
#
# OPENCLAW_GATEWAY_URL:  Gateway base URL. Default: http://127.0.0.1:18789/v1
# OPENCLAW_GATEWAY_TOKEN: Gateway auth token.
#   Find it: openclaw gateway status, or ~/.openclaw/openclaw.json →
#   gateway.auth.token
# OPENCLAW_AGENT_ID: Which OpenClaw agent to target. Default: main
#   List agents: python3 -c "import json,os; d=json.load(open(os.path.expanduser('~/.openclaw/openclaw.json'))); [print(a['id']) for a in d.get('agents',{}).get('list',[])]"
# OPENCLAW_SESSION_KEY: Pin voice calls to a specific session for shared memory.
#   Omit to create a fresh session per call.
#   To share a session with another channel (e.g. Telegram), use that channel's
#   session key — find it by asking your agent: "what is your session key?"
# -----------------------------------------------------------------------------
OPENCLAW_GATEWAY_URL=http://127.0.0.1:18789/v1
OPENCLAW_GATEWAY_TOKEN=your_openclaw_gateway_token
OPENCLAW_AGENT_ID=your_agent_id
OPENCLAW_SESSION_KEY=your_session_key
