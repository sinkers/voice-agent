# LiveKit server WebSocket URL (wss://...)
LIVEKIT_URL=wss://your-project.livekit.cloud

# LiveKit API credentials (from your LiveKit Cloud dashboard)
LIVEKIT_API_KEY=your_api_key
LIVEKIT_API_SECRET=your_api_secret

# JSON array of available agents. Each entry must match a registered LiveKit agent worker name.
LIVEKIT_AGENTS=[{"id":"openclaw-alex","name":"Alex"},{"id":"openclaw-elysse","name":"Elysse"}]

# Comma-separated list of allowed CORS origins. Use * for development.
CORS_ORIGINS=*
